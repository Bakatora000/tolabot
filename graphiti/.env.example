GRAPHITI_TELEMETRY_ENABLED=false
GRAPHITI_WORKDIR=/home/appuser/project/graphiti
GRAPHITI_IMPORT_DIR=/home/appuser/project/graphiti/imports
GRAPHITI_KUZU_DB_PATH=/home/appuser/project/graphiti/data/graphiti.kuzu

# Graphiti roles are intentionally separated from the live chat model.
# Suggested split:
# - Windows live chat bot: qwen3.5
# - Graphiti offline extraction LLM: llama3.3:7b
# - Graphiti embeddings: nomic-embed-text

GRAPHITI_LLM_API_KEY=ollama
GRAPHITI_LLM_BASE_URL=http://127.0.0.1:11434/v1
GRAPHITI_LLM_MODEL=llama3.3:7b

GRAPHITI_EMBEDDING_API_KEY=ollama
GRAPHITI_EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
GRAPHITI_EMBEDDING_MODEL=nomic-embed-text
