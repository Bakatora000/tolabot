MEM0_API_KEY=change-me
MEM0_HOST=127.0.0.1
MEM0_PORT=8000
LOG_LEVEL=INFO
MEM0_DEFAULT_LIMIT=5
MEM0_MAX_LIMIT=10

# Use "file" for local MVP runs without external dependencies.
# Switch to "mem0" once mem0 + Qdrant are installed and configured.
MEMORY_BACKEND=file
DATA_DIR=./data
FILE_STORE_PATH=./data/memory_store.json

MEM0_QDRANT_HOST=127.0.0.1
MEM0_QDRANT_PORT=6333
MEM0_QDRANT_COLLECTION=mem0
MEM0_QDRANT_ON_DISK=true
MEM0_HISTORY_DB_PATH=./data/history.db

MEM0_LLM_PROVIDER=openai
MEM0_LLM_MODEL=gpt-4.1-mini
MEM0_EMBEDDER_PROVIDER=openai
MEM0_EMBEDDER_MODEL=text-embedding-3-small

# Provider secrets depend on the mem0 stack you choose.
# Example for the default OSS path:
# OPENAI_API_KEY=sk-...
