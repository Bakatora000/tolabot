MEM0_API_KEY=change-me
MEM0_ADMIN_KEY=change-me-admin
MEM0_HOST=127.0.0.1
MEM0_PORT=8000
MEM0_ADMIN_HOST=127.0.0.1
MEM0_ADMIN_PORT=9000
LOG_LEVEL=INFO
MEM0_DEFAULT_LIMIT=5
MEM0_MAX_LIMIT=10
MEM0_ADMIN_EXPORT_LIMIT=1000

# Use "file" for the simplest local MVP runs.
# Use "mem0" for the validated Mem0 backend path.
MEMORY_BACKEND=file
DATA_DIR=./data
FILE_STORE_PATH=./data/memory_store.json
USER_REGISTRY_PATH=./data/user_registry.json

MEM0_QDRANT_HOST=127.0.0.1
MEM0_QDRANT_PORT=6333
MEM0_QDRANT_PATH=./data/qdrant
MEM0_QDRANT_URL=
MEM0_QDRANT_API_KEY=
MEM0_QDRANT_COLLECTION=mem0
MEM0_QDRANT_ON_DISK=true
MEM0_HISTORY_DB_PATH=./data/history.db

MEM0_LLM_PROVIDER=lmstudio
MEM0_LLM_MODEL=dummy-local-model
MEM0_LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
MEM0_EMBEDDER_PROVIDER=fastembed
MEM0_EMBEDDER_MODEL=BAAI/bge-small-en-v1.5
MEM0_EMBEDDER_DIMS=384

# Provider secrets depend on the mem0 stack you choose.
# Example if you switch back to OpenAI-backed extraction:
# OPENAI_API_KEY=sk-...
