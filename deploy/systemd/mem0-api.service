[Unit]
Description=mem0 API service
After=network.target

[Service]
Type=simple
User=vhserver
Group=vhserver
WorkingDirectory=/home/vhserver/bt
EnvironmentFile=/home/vhserver/bt/.env
ExecStart=/home/vhserver/bt/.venv/bin/uvicorn main:app --host ${MEM0_HOST} --port ${MEM0_PORT}
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
